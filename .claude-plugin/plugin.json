{
  "name": "cavemaenggu",
  "description": "Ultra-compressed communication mode (caveman + 맹구 fork). Cuts ~75% of tokens while keeping full technical accuracy by speaking like a smart caveman; switches to Korean 개조식/전보체 for the maeng-gu family.",
  "author": {
    "name": "tk4n9",
    "url": "https://github.com/tk4n9"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/cavemaenggu-activate.js\"",
            "timeout": 5,
            "statusMessage": "Loading cavemaenggu mode..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/cavemaenggu-mode-tracker.js\"",
            "timeout": 5,
            "statusMessage": "Tracking cavemaenggu mode..."
          }
        ]
      }
    ]
  }
}
